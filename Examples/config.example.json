{
  "enabled": false,
  "schedule": {
    "hour": 2,
    "minute": 30
  },
  "archive": {
    "basePath": "~/Archive/Quarantine"
  },
  "roots": [
    {
      "name": "downloads",
      "path": "~/Downloads",
